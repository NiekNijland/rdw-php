{
    "name": "nieknijland/rdw-opendata-php",
    "description": "A typed PHP client for the RDW Open Data Voertuigen datasets.",
    "keywords": [
        "NiekNijland",
        "rdw-opendata-php"
    ],
    "homepage": "https://github.com/NiekNijland/rdw-opendata-php",
    "license": "MIT",
    "authors": [
        {
            "name": "NiekNijland",
            "email": "niek@nijland.cc",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.8",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^10.3.2",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "NiekNijland\\RDW\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NiekNijland\\RDW\\Tests\\": "tests"
        }
    },
    "scripts-descriptions": {
        "pint": "Run the DIJ-digital Laravel Pint config in fix mode.",
        "test:lint": "Run the DIJ-digital Laravel Pint config in check mode.",
        "analyse": "Run PHPStan at level 8 with strict rules.",
        "rdw:generate": "Regenerate field enums and record classes from the overrides + metadata snapshots.",
        "rdw:generate:check": "Fail if generated files would change. CI-friendly drift detector.",
        "codestyle": "Run Pint + PHPStan in sequence."
    },
    "bin": [
        "bin/rdw-generate"
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html build/coverage",
        "pint": "@php vendor/bin/pint --config https://raw.githubusercontent.com/DIJ-digital/pint-config/main/pint.json",
        "test:lint": "@php vendor/bin/pint --config https://raw.githubusercontent.com/DIJ-digital/pint-config/main/pint.json --test",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=2G",
        "rdw:generate": "@php bin/rdw-generate",
        "rdw:generate:check": "@php bin/rdw-generate --check",
        "codestyle": [
            "@pint",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
